# 复制本文件为 .env 并填入你自己的访问令牌（.env 已被 .gitignore 排除，不会提交）
# 魔搭 ModelScope 令牌获取：modelscope.cn → 右上角头像 → 访问令牌(Access Token)
MODELSCOPE_API_KEY=ms-在此填入你的令牌

# OpenAI 兼容端点（魔搭 API-Inference）
MS_BASE_URL=https://api-inference.modelscope.cn/v1

# 模型名（魔搭上可用的模型，例：ZhipuAI/GLM-5.1 或 deepseek-ai/DeepSeek-V4-Pro）
MS_MODEL=deepseek-ai/DeepSeek-V4-Pro

# —— 可选：联网搜索 provider（默认 DuckDuckGo 免 key；配了 key 则优先用对应 API）——
# SEARCH_PROVIDER=auto
# TAVILY_API_KEY=
# BOCHA_API_KEY=
# SERPER_API_KEY=
